# ----------------------------
# Public routing
# ----------------------------
PUBLIC_DOMAIN=staysaga.example.com
KEYCLOAK_DOMAIN=auth.staysaga.example.com
SV_API_PREFIX=/api
ACME_EMAIL=ops@example.com
GITHUB_TOKEN=ghp_your_read_packages_token

# ----------------------------
# Bootstrap Keycloak admin user
# ----------------------------
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change_me_strong_admin_password

# ----------------------------
# PostgreSQL shared instance
# ----------------------------
POSTGRES_USER=staysaga
POSTGRES_PASSWORD=change_me_strong_postgres_password
POSTGRES_DEFAULT_DB=postgres

# App databases
USER_DB_NAME=ss_us
PROPERTY_DB_NAME=ss_ps
ORDER_DB_NAME=ss_os
PAYMENT_DB_NAME=ss_ps2

# Keycloak database (same postgres instance and same DB user/password)
KEYCLOAK_DB_NAME=keycloak

# ----------------------------
# Keycloak realm + clients
# ----------------------------
KEYCLOAK_REALM=stay-saga
KEYCLOAK_API_CLIENT_ID=api-gateway
KEYCLOAK_API_AUDIENCE=api-gateway
KEYCLOAK_API_CLIENT_SECRET=change_me_api_client_secret
KEYCLOAK_ADMIN_CLIENT_ID=user-service
KEYCLOAK_ADMIN_CLIENT_SECRET=change_me_user_service_client_secret

# ----------------------------
# Payment integration (required by payment service)
# ----------------------------
PAYOS_CLIENT_ID=YOUR_PAYOS_CLIENT_ID
PAYOS_API_KEY=YOUR_PAYOS_API_KEY
PAYOS_CHECKSUM_KEY=YOUR_PAYOS_CHECKSUM_KEY
